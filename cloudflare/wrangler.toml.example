name = "taifex-high-low-trigger"
main = "high-low-trigger-worker.js"
compatibility_date = "2026-07-01"

# UTC times. Asia/Taipei is UTC+8.
# 07:01/07:11/07:21 UTC = 15:01/15:11/15:21 Taipei.
# 08:01/08:21/08:41 UTC = 16:01/16:21/16:41 Taipei backups.
[triggers]
crons = [
  "1,11,21,31,41,51 7 * * 1-5",
  "1,21,41 8 * * 1-5",
  "11,41 9 * * 1-5"
]
